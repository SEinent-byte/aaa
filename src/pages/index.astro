  )}

  <!-- Sin productos -->
  {!envMissing && productos.length === 0 && (
    <div style="text-align:center;padding:80px 20px;color:#334155;">
      <div style="width:72px;height:72px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:20px;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
