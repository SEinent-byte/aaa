        <select name="categoria" required class="field">
          <option value="">Categoría</option>
          {CATEGORIAS.map(cat => <option value={cat}>{cat}</option>)}
        </select>
        <input name="precio" type="number" step="0.01" min="0" placeholder="Precio (S/)" required class="field" />
        <input name="stock" type="number" min="0" placeholder="Stock" required class="field" />
        <textarea name="descripcion" placeholder="Descripción (opcional)" rows="2" class="field" style="grid-column:1/-1;resize:none;"></textarea>
      </div>
      <div>
        <div style="font-size:11px;color:#475569;margin-bottom:8px;font-weight:500;">IMAGEN DEL PRODUCTO</div>
        <div class="dropzone">
          <input name="imagen" type="file" accept="image/jpeg,image/png,image/webp,image/gif" />
          <div class="drop-placeholder" style="display:flex;flex-direction:column;align-items:center;gap:6px;">
