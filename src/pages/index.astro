---
import '../styles/global.css';
import { createClient } from '@supabase/supabase-js';

export const prerender = false;

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

const CATEGORIAS = [
  'Microcontroladores','Herramientas','Componentes',
  'Sensores','Actuadores','Fuentes de poder','Cables y conectores'
];

const CAT: Record<string, { border:string; glow:string; badge:string; badgeText:string; dot:string }> = {
  'Microcontroladores': { border:'border-blue-500/30',    glow:'hover:shadow-blue-500/10',    badge:'bg-blue-500/15 border border-blue-500/30',    badgeText:'text-blue-300',    dot:'bg-blue-400'    },
  'Herramientas':       { border:'border-amber-500/30',   glow:'hover:shadow-amber-500/10',   badge:'bg-amber-500/15 border border-amber-500/30',   badgeText:'text-amber-300',   dot:'bg-amber-400'   },
  'Componentes':        { border:'border-purple-500/30',  glow:'hover:shadow-purple-500/10',  badge:'bg-purple-500/15 border border-purple-500/30',  badgeText:'text-purple-300',  dot:'bg-purple-400'  },
  'Sensores':           { border:'border-emerald-500/30', glow:'hover:shadow-emerald-500/10', badge:'bg-emerald-500/15 border border-emerald-500/30', badgeText:'text-emerald-300', dot:'bg-emerald-400' },
  'Actuadores':         { border:'border-rose-500/30',    glow:'hover:shadow-rose-500/10',    badge:'bg-rose-500/15 border border-rose-500/30',    badgeText:'text-rose-300',    dot:'bg-rose-400'    },
  'Fuentes de poder':   { border:'border-yellow-500/30',  glow:'hover:shadow-yellow-500/10',  badge:'bg-yellow-500/15 border border-yellow-500/30',  badgeText:'text-yellow-300',  dot:'bg-yellow-400'  },
  'Cables y conectores':{ border:'border-cyan-500/30',    glow:'hover:shadow-cyan-500/10',    badge:'bg-cyan-500/15 border border-cyan-500/30',    badgeText:'text-cyan-300',    dot:'bg-cyan-400'    },
};
const DEF = { border:'border-slate-700/50', glow:'hover:shadow-slate-500/10', badge:'bg-slate-700/50 border border-slate-600/30', badgeText:'text-slate-400', dot:'bg-slate-400' };

let productos: any[] = [];
let supabaseError: any = null;
let envMissing = false;

if (!supabaseUrl || !supabaseKey) {
  envMissing = true;
} else {
  const supabase = createClient(supabaseUrl, supabaseKey);
  const response = await supabase.from('productos').select('*').order('creado_en', { ascending: false });
  productos = response.data || [];
  supabaseError = response.error;
}
---

<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <title>ElectroShop — Componentes & Electrónica</title>
  <style>
    /* ── base ── */
    *, *::before, *::after { box-sizing: border-box; }

    body {
      background: #020617;
      background-image:
        radial-gradient(ellipse 80% 40% at 50% -10%, rgba(6,182,212,.07) 0%, transparent 70%),
        radial-gradient(ellipse 60% 30% at 80% 110%, rgba(139,92,246,.05) 0%, transparent 60%);
      min-height: 100vh;
    }

    /* ── card ── */
    .product-card {
      background: linear-gradient(145deg, #1e293b 0%, #0f172a 100%);
      transition: transform .28s cubic-bezier(.22,1,.36,1), box-shadow .28s ease;
      will-change: transform;
    }
    .product-card:hover { transform: translateY(-4px); }

    /* ── imagen centrada, nunca estirada ── */
    .img-wrap {
      position: relative;
      width: 100%;
      aspect-ratio: 4/3;
      overflow: hidden;
      background: #1e293b;
    }
    .img-wrap img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      transition: transform .5s cubic-bezier(.22,1,.36,1), filter .3s ease;
    }
    .product-card:hover .img-wrap img { transform: scale(1.06); filter: brightness(1.05); }

    /* degradado inferior sobre imagen */
    .img-wrap::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(15,23,42,.75) 0%, rgba(15,23,42,.15) 45%, transparent 100%);
      pointer-events: none;
    }

    /* ── badge categoría ── */
    .cat-badge {
      position: absolute;
      top: 10px; left: 10px;
      z-index: 2;
      display: flex; align-items: center; gap: 5px;
      padding: 4px 10px;
      border-radius: 999px;
      font-size: 11px; font-weight: 600;
      backdrop-filter: blur(8px);
      letter-spacing: .02em;
    }
    .cat-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }

    /* ── precio ── */
    .price-tag {
      font-size: 1.35rem;
      font-weight: 800;
      background: linear-gradient(135deg, #34d399 0%, #059669 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      line-height: 1;
    }

    /* ── botones acción ── */
    .btn-action {
      display: flex; align-items: center; justify-content: center; gap: 5px;
      flex: 1; padding: 8px 6px;
      border-radius: 10px;
      font-size: 12px; font-weight: 600;
      transition: background .2s, transform .15s;
      cursor: pointer; border: none;
    }
    .btn-action:active { transform: scale(.96); }
    .btn-del  { background: rgba(239,68,68,.1);  color: #fca5a5; border: 1px solid rgba(239,68,68,.2); }
    .btn-del:hover  { background: rgba(239,68,68,.2); }
    .btn-edit { background: rgba(56,189,248,.1);  color: #7dd3fc; border: 1px solid rgba(56,189,248,.2); }
    .btn-edit:hover { background: rgba(56,189,248,.2); }

    /* ── placeholder sin imagen ── */
    .img-placeholder {
      position: absolute; inset: 0;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      gap: 8px; color: #334155;
    }

    /* ── filtros ── */
    .filtro-btn {
      display: flex; align-items: center; gap: 5px;
      padding: 6px 14px;
      border-radius: 999px;
      font-size: 12px; font-weight: 600;
      border: 1px solid rgba(255,255,255,.07);
      background: rgba(255,255,255,.04);
      color: #94a3b8;
      cursor: pointer;
      transition: background .2s, color .2s, border-color .2s, transform .15s;
    }
    .filtro-btn:hover { background: rgba(255,255,255,.08); color: #e2e8f0; }
    .filtro-btn:active { transform: scale(.96); }
    .filtro-btn.active { background: #06b6d4; color: #0f172a; border-color: #06b6d4; }

    /* ── modales ── */
    .modal-backdrop {
      position: fixed; inset: 0; z-index: 50;
      display: flex; align-items: center; justify-content: center;
      background: rgba(0,0,0,.65);
      backdrop-filter: blur(6px);
      padding: 16px;
      overflow-y: auto;
    }
    .modal-box {
      background: linear-gradient(160deg, #1e293b 0%, #0f172a 100%);
      border: 1px solid rgba(255,255,255,.08);
      border-radius: 20px;
      box-shadow: 0 25px 60px rgba(0,0,0,.6);
      width: 100%; max-width: 480px;
      margin: auto;
    }

    /* ── input / select / textarea ── */
    .field {
      width: 100%; padding: 11px 14px;
      background: rgba(255,255,255,.04);
      border: 1px solid rgba(255,255,255,.09);
      border-radius: 10px;
      color: #e2e8f0; font-size: 13.5px;
      transition: border-color .2s, box-shadow .2s;
      outline: none;
    }
    .field:focus { border-color: #06b6d4; box-shadow: 0 0 0 3px rgba(6,182,212,.12); }
    .field::placeholder { color: #475569; }

    /* ── dropzone ── */
    .dropzone {
      position: relative;
      border: 2px dashed rgba(255,255,255,.1);
      border-radius: 12px;
      padding: 20px;
      text-align: center;
      cursor: pointer;
      transition: border-color .2s, background .2s;
    }
    .dropzone:hover { border-color: #06b6d4; background: rgba(6,182,212,.04); }
    .dropzone input[type="file"] { position: absolute; inset: 0; opacity: 0; cursor: pointer; }

    /* ── btn submit ── */
    .btn-submit {
      width: 100%; padding: 12px;
      border-radius: 12px;
      font-weight: 700; font-size: 14px;
      border: none; cursor: pointer;
      transition: opacity .2s, transform .15s;
    }
    .btn-submit:hover { opacity: .9; }
    .btn-submit:active { transform: scale(.98); }
    .btn-crear  { background: linear-gradient(135deg,#06b6d4,#0284c7); color: #fff; }
    .btn-editar { background: linear-gradient(135deg,#38bdf8,#0ea5e9); color: #0f172a; }
    .btn-submit:disabled { opacity: .5; cursor: not-allowed; }

    /* ── animación entrada cards ── */
    @keyframes fadeInUp {
      from { opacity:0; transform:translateY(22px); }
      to   { opacity:1; transform:translateY(0); }
    }
    .card-enter {
      opacity: 0;
      animation: fadeInUp .45s cubic-bezier(.22,1,.36,1) forwards;
    }

    /* ── hero ── */
    @keyframes heroFade {
      from { opacity:0; transform:translateY(16px); }
      to   { opacity:1; transform:translateY(0); }
    }
    .hero-section {
      position: relative;
      overflow: hidden;
      padding: 72px 20px 56px;
      text-align: center;
    }
    .hero-section::before {
      content:'';
      position:absolute; inset:0;
      background:
        radial-gradient(ellipse 70% 60% at 50% 0%, rgba(6,182,212,.13) 0%, transparent 65%),
        radial-gradient(ellipse 40% 40% at 20% 80%, rgba(99,102,241,.08) 0%, transparent 60%);
      pointer-events:none;
    }
    .hero-badge {
      display:inline-flex; align-items:center; gap:6px;
      padding:5px 14px;
      border:1px solid rgba(6,182,212,.3);
      border-radius:999px;
      font-size:12px; font-weight:600; color:#06b6d4;
      background:rgba(6,182,212,.08);
      margin-bottom:20px;
      animation: heroFade .5s .1s both;
    }
    .hero-title {
      font-size:clamp(2rem,5vw,3.2rem);
      font-weight:900;
      line-height:1.1;
      letter-spacing:-.03em;
      color:#f1f5f9;
      background: linear-gradient(135deg,#f1f5f9 30%,#94a3b8 100%);
      -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
      margin:0 0 16px;
      animation: heroFade .5s .2s both;
    }
    .hero-sub {
      max-width:520px; margin:0 auto 32px;
      font-size:15px; color:#64748b; line-height:1.7;
      animation: heroFade .5s .3s both;
    }
    .hero-cta {
      display:inline-flex; align-items:center; gap:8px;
      padding:13px 28px;
      background:linear-gradient(135deg,#06b6d4,#6366f1);
      color:#fff; font-size:14px; font-weight:700;
      border:none; border-radius:12px; cursor:pointer;
      box-shadow: 0 0 30px rgba(6,182,212,.25);
      transition: transform .2s, box-shadow .2s;
      animation: heroFade .5s .4s both;
    }
    .hero-cta:hover { transform:translateY(-2px); box-shadow:0 0 40px rgba(6,182,212,.35); }

    /* ── stats bar ── */
    .stats-bar {
      display:flex; justify-content:center; flex-wrap:wrap; gap:0;
      border:1px solid rgba(255,255,255,.07);
      border-radius:16px;
      overflow:hidden;
      max-width:560px; margin:40px auto 0;
      animation: heroFade .5s .5s both;
    }
    .stat-item {
      flex:1; min-width:120px;
      padding:16px 20px; text-align:center;
      border-right:1px solid rgba(255,255,255,.07);
      background:rgba(255,255,255,.02);
    }
    .stat-item:last-child { border-right:none; }
    .stat-num { font-size:22px; font-weight:800; color:#f1f5f9; line-height:1; }
    .stat-lbl { font-size:11px; color:#475569; font-weight:500; margin-top:4px; letter-spacing:.04em; }

    /* ── features ── */
    .features-grid {
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
      gap:12px;
      max-width:1280px; margin:0 auto;
      padding:0 20px 40px;
    }
    .feature-card {
      display:flex; align-items:flex-start; gap:12px;
      padding:16px 18px;
      background:rgba(255,255,255,.03);
      border:1px solid rgba(255,255,255,.06);
      border-radius:14px;
      transition:background .2s, border-color .2s, transform .2s;
    }
    .feature-card:hover { background:rgba(255,255,255,.05); border-color:rgba(255,255,255,.1); transform:translateY(-2px); }
    .feature-icon {
      width:38px; height:38px; border-radius:10px;
      display:flex; align-items:center; justify-content:center;
      flex-shrink:0;
    }

    /* ── WhatsApp widget ── */
    @keyframes waPulse {
      0%,100% { box-shadow:0 0 0 0 rgba(37,211,102,.4); }
      50%      { box-shadow:0 0 0 10px rgba(37,211,102,0); }
    }
    @keyframes waBounce {
      0%,100% { transform:scale(1); }
      50%      { transform:scale(1.08); }
    }
    @keyframes waSlideUp {
      from { opacity:0; transform:translateY(12px) scale(.97); }
      to   { opacity:1; transform:translateY(0) scale(1); }
    }
    #wa-fab {
      position:fixed; bottom:24px; right:24px; z-index:100;
      width:54px; height:54px;
      background:linear-gradient(135deg,#25d366,#128c3e);
      border:none; border-radius:50%; cursor:pointer;
      display:flex; align-items:center; justify-content:center;
      animation: waPulse 2.5s infinite;
      transition:transform .2s;
    }
    #wa-fab:hover { animation:waBounce .4s ease; }
    #wa-popup {
      position:fixed; bottom:90px; right:24px; z-index:100;
      width:320px;
      background:linear-gradient(160deg,#1e293b,#0f172a);
      border:1px solid rgba(255,255,255,.1);
      border-radius:18px;
      box-shadow:0 20px 50px rgba(0,0,0,.5);
      overflow:hidden;
      display:none;
    }
    #wa-popup.open { display:block; animation: waSlideUp .3s cubic-bezier(.22,1,.36,1); }
    .wa-head {
      display:flex; align-items:center; gap:10px;
      padding:14px 16px;
      background:linear-gradient(135deg,#128c3e,#075e54);
    }
    .wa-avatar {
      width:38px; height:38px; border-radius:50%;
      background:rgba(255,255,255,.15);
      display:flex; align-items:center; justify-content:center;
      flex-shrink:0;
    }
    .wa-online { width:9px;height:9px;border-radius:50%;background:#4ade80;border:2px solid #075e54;position:absolute;bottom:0;right:0; }
    .wa-msgs {
      padding:16px; display:flex; flex-direction:column; gap:10px;
      max-height:200px; overflow-y:auto;
    }
    .wa-bubble {
      padding:10px 13px;
      border-radius:0 12px 12px 12px;
      font-size:13px; line-height:1.5; color:#e2e8f0;
      background:rgba(255,255,255,.07);
      border:1px solid rgba(255,255,255,.06);
      max-width:90%;
    }
    .wa-input-row {
      display:flex; gap:8px;
      padding:12px 14px;
      border-top:1px solid rgba(255,255,255,.07);
      background:rgba(0,0,0,.2);
    }
    #wa-input {
      flex:1; padding:9px 12px;
      background:rgba(255,255,255,.06);
      border:1px solid rgba(255,255,255,.1);
      border-radius:10px;
      color:#e2e8f0; font-size:13px; outline:none;
      transition:border-color .2s;
    }
    #wa-input:focus { border-color:#25d366; }
    #wa-input::placeholder { color:#475569; }
    #wa-send {
      width:38px; height:38px;
      background:linear-gradient(135deg,#25d366,#128c3e);
      border:none; border-radius:10px; cursor:pointer;
      display:flex; align-items:center; justify-content:center;
      transition:transform .15s;
      flex-shrink:0;
    }
    #wa-send:hover { transform:scale(1.1); }
  </style>
</head>
<body>

<!-- ── HEADER ── -->
<header style="background:rgba(2,6,23,.85); backdrop-filter:blur(12px); border-bottom:1px solid rgba(255,255,255,.06); position:sticky; top:0; z-index:40;">
  <div style="max-width:1280px; margin:0 auto; padding:0 20px; height:60px; display:flex; align-items:center; justify-content:space-between;">
    <div style="display:flex; align-items:center; gap:10px;">
      <!-- ícono rayo SVG -->
      <div style="width:36px;height:36px;background:linear-gradient(135deg,#06b6d4,#6366f1);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <svg width="20" height="20" fill="none" viewBox="0 0 24 24"><path d="M13 2L4.09 12.96A1 1 0 005 14.5h6.5L11 22l8.91-10.96A1 1 0 0019 9.5H12.5L13 2Z" fill="white"/></svg>
      </div>
      <div>
        <div style="font-size:17px;font-weight:800;color:#f1f5f9;letter-spacing:-.3px;">ElectroShop</div>
        <div style="font-size:11px;color:#475569;margin-top:-1px;">Componentes & Electrónica</div>
      </div>
    </div>
    <div style="display:flex;align-items:center;gap:12px;">
      <div style="display:flex;align-items:center;gap:6px;padding:5px 12px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:999px;">
        <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="#64748b" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7H4a2 2 0 00-2 2v10a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2zM16 3H8l-2 4h12l-2-4z"/></svg>
        <span style="font-size:12px;color:#64748b;font-weight:600;">{productos.length} productos</span>
      </div>
      <button id="btn-abrir-form" style="display:flex;align-items:center;gap:6px;padding:8px 16px;background:linear-gradient(135deg,#06b6d4,#0284c7);color:#fff;border:none;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;transition:opacity .2s;" onmouseover="this.style.opacity='.85'" onmouseout="this.style.opacity='1'">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
        Agregar
      </button>
    </div>
  </div>
</header>

<!-- ── HERO ── -->
<section class="hero-section">
  <div class="hero-badge">
    <svg width="13" height="13" fill="#06b6d4" viewBox="0 0 24 24"><path d="M13 2L4.09 12.96A1 1 0 005 14.5h6.5L11 22l8.91-10.96A1 1 0 0019 9.5H12.5L13 2Z"/></svg>
    Tu tienda de electrónica de confianza
  </div>
  <h1 class="hero-title">Componentes de calidad<br/>para tus proyectos</h1>
  <p class="hero-sub">Microcontroladores, sensores, herramientas y más. Todo lo que necesitas para dar vida a tus ideas, con los mejores precios del mercado.</p>
  <button class="hero-cta" onclick="document.getElementById('seccion-productos')?.scrollIntoView({behavior:'smooth'})">
    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
    Ver Catálogo
  </button>
  <div class="stats-bar">
    <div class="stat-item">
      <div class="stat-num">{productos.length}</div>
      <div class="stat-lbl">PRODUCTOS</div>
    </div>
    <div class="stat-item">
      <div class="stat-num">{CATEGORIAS.length}</div>
      <div class="stat-lbl">CATEGORÍAS</div>
    </div>
    <div class="stat-item">
      <div class="stat-num">24h</div>
      <div class="stat-lbl">ATENCIÓN</div>
    </div>
    <div class="stat-item">
      <div class="stat-num">100%</div>
      <div class="stat-lbl">GARANTÍA</div>
    </div>
  </div>
</section>

<!-- ── FEATURES ── -->
<div class="features-grid">
  <div class="feature-card">
    <div class="feature-icon" style="background:rgba(6,182,212,.12);">
      <svg width="20" height="20" fill="none" stroke="#06b6d4" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/></svg>
    </div>
    <div>
      <div style="font-size:13px;font-weight:700;color:#e2e8f0;margin-bottom:3px;">Envío Rápido</div>
      <div style="font-size:12px;color:#475569;line-height:1.4;">Despacho el mismo día en pedidos antes de las 3 pm.</div>
    </div>
  </div>
  <div class="feature-card">
    <div class="feature-icon" style="background:rgba(52,211,153,.12);">
      <svg width="20" height="20" fill="none" stroke="#34d399" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
    </div>
    <div>
      <div style="font-size:13px;font-weight:700;color:#e2e8f0;margin-bottom:3px;">Garantía de Calidad</div>
      <div style="font-size:12px;color:#475569;line-height:1.4;">Productos verificados y con garantía de funcionamiento.</div>
    </div>
  </div>
  <div class="feature-card">
    <div class="feature-icon" style="background:rgba(251,191,36,.12);">
