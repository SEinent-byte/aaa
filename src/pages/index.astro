            }
            <!-- badge categoría -->
            <div class={`cat-badge ${c.badge} ${c.badgeText}`}>
              <span class={`cat-dot ${c.dot}`}></span>
              {producto.categoria || 'General'}
            </div>
          </div>

          <!-- info -->
          <div style="padding:14px 16px;display:flex;flex-direction:column;flex:1;gap:6px;">
            <h3 style="font-size:14px;font-weight:700;color:#f1f5f9;line-height:1.4;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{producto.nombre}</h3>
            <p style="font-size:12px;color:#475569;line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;flex:1;">{producto.descripcion || 'Sin descripción'}</p>

            <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-top:4px;">
              <div>
                <div style="font-size:10px;color:#475569;font-weight:500;letter-spacing:.04em;margin-bottom:2px;">PRECIO</div>
                <span class="price-tag">S/ {Number(producto.precio).toFixed(2)}</span>
              </div>
              <div style="text-align:right;">
                <div style="font-size:10px;color:#475569;font-weight:500;letter-spacing:.04em;margin-bottom:2px;">STOCK</div>
                <div style="display:flex;align-items:center;gap:4px;">
                  <span style={`width:7px;height:7px;border-radius:50%;flex-shrink:0;background:${producto.stock > 0 ? '#34d399' : '#f87171'};`}></span>
                  <span style={`font-size:13px;font-weight:700;color:${producto.stock > 0 ? '#e2e8f0' : '#f87171'};`}>{producto.stock} ud.</span>
                </div>
              </div>
            </div>

            <div style="display:flex;gap:8px;margin-top:8px;">
              <button class="btn-action btn-del" data-delete-id={producto.id}>
                <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                Eliminar
              </button>
              <button class="btn-action btn-edit" data-update-id={producto.id}>
                <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                Editar
              </button>
            </div>
          </div>
        </article>
      );
    })}
  </div>
</main>

